# Birthday Invitation — environment variables
# Copy to .env and fill in. These are injected into the frontend at container
# start (see infra/inject-env.sh) and consumed by docker compose.
#
# The app is multi-event: the admin (/admin) creates and manages any number of
# events, each with its own theme, invitation link (/e/<slug>), QR code and
# RSVP list. The BIRTHDAY_* / EVENT_* values below seed the *default* event
# (served at /) on first start; once you edit that event in the admin, these are
# no longer applied. New events are created entirely from the admin UI.

# Birthday person's name (seeds the default event)
BIRTHDAY_PERSON=Léo

# Birthday person's age
BIRTHDAY_AGE=5

# Event date (YYYY-MM-DD)
EVENT_DATE=2025-09-06

# Event time
EVENT_TIME=15h00 - 17h00

# Town
EVENT_TOWN=Artigues-près-Bordeaux

# Event location / address
EVENT_LOCATION=🏠 Chez Léo - 1 rue Exemple, 33370 Artigues-près-Bordeaux

# Dress code
DRESS_CODE=Tenue de rechange ou maillot de bain ! Il y aura des jeux d'eau 💦

# Optional "respond by" date (YYYY-MM-DD). When set and passed, the invitation
# shows that RSVPs are closed and the API rejects new submissions. Leave blank
# to keep RSVPs open indefinitely.
EVENT_RSVP_DEADLINE=

# Base domain used by the Traefik router (compose.yml) -> leo-birthday.${DOMAIN}
DOMAIN=example.com

# Optional comma-separated allow-list of cross-origin sites permitted to call the
# API. Leave blank for the default same-origin-only behaviour.
CORS_ORIGIN=

# Database backup sidecar (compose.yml "backup" service).
# BACKUP_KEEP: number of snapshots to retain. BACKUP_INTERVAL: seconds between runs.
BACKUP_KEEP=14
BACKUP_INTERVAL=86400

# Admin authentication (Better Auth, email + password). The single admin
# account is seeded from ADMIN_EMAIL / ADMIN_PASSWORD on first start (idempotent
# — changing them later does NOT update an existing account). Password must be
# at least 8 characters.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-secret
# Optional display name for the seeded admin (defaults to "Admin").
ADMIN_NAME=Admin

# Session signing secret for Better Auth. REQUIRED in production (the server
# refuses to start without it). Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Public origin the app is served from, used by Better Auth to validate request
# origins and scope session cookies. Behind a proxy (Traefik) set this to the
# external HTTPS URL, e.g. https://leo-birthday.example.com. May be left blank
# for same-origin local development.
BETTER_AUTH_URL=

# Number of proxy hops in front of the backend, used for per-IP rate limiting.
# Default 1 matches the Traefik -> Node chain. Set 0 for direct access.
TRUST_PROXY=1
