{
    "name": "@birthday-invitation/backend",
    "version": "1.0.0",
    "description": "Birthday invitation backend - Express.js API server",
    "type": "module",
    "private": true,
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "build": "echo 'No build step required for backend'",
        "test": "vitest",
        "test:run": "vitest run",
        "test:watch": "vitest --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "clean": "rm -rf node_modules *.db"
    },
    "dependencies": {
        "better-sqlite3": "^12.10.1",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.5.0",
        "globals": "^16.5.0",
        "supertest": "^7.1.1",
        "vitest": "^4.1.8"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
