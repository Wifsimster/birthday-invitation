{
    "name": "@birthday-invitation/backend",
    "version": "1.0.1",
    "description": "Birthday invitation backend - Express.js API server",
    "type": "module",
    "private": true,
    "main": "server.ts",
    "scripts": {
        "start": "node server.ts",
        "dev": "node --watch server.ts",
        "build": "echo 'No build step required — Node strips types at runtime'",
        "test": "vitest",
        "test:run": "vitest run",
        "test:watch": "vitest --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "clean": "rm -rf node_modules *.db"
    },
    "dependencies": {
        "better-auth": "^1.6.18",
        "better-sqlite3": "^12.10.1",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.3",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.5.0",
        "globals": "^17.6.0",
        "supertest": "^7.2.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vitest": "^4.1.8"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
